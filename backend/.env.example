# Copy this file to .env and fill in your real values.
# NEVER commit .env; only .env.example is tracked by git.
#
# Source of truth:
# - backend/app/config.py for Settings-backed environment variables
# - backend/app/main.py and backend/app/routes/upload.py for UPLOAD_DIR

# PostgreSQL
DATABASE_URL=postgresql://isms_user:isms_password@db:5432/isms_db

# JWT
JWT_SECRET=generate_with_openssl_rand_-base64_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis
REDIS_URL=redis://redis:6379

# App
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
# Match approval mode:
# - club_admin   => club manual approval still applies
# - referee_only => auto-assigned matchmaking matches skip club approval and go straight to referee flow
MATCH_APPROVAL_MODE=club_admin

# OpenRouter (preferred for AI insights; optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
# Optional metadata headers for OpenRouter rankings/analytics
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=ISMS

# Anthropic (fallback; optional)
ANTHROPIC_API_KEY=

# Firebase Cloud Messaging (optional)
# Place your Firebase service account JSON at this path (also in .gitignore).
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Upload storage path (used outside Settings, but read directly by the app)
UPLOAD_DIR=/app/uploads
